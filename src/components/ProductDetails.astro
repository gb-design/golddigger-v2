---
import { product } from '../data/product'

const ingredients = [
  {
    name: 'Kakaomantel',
    description: 'Feiner Überzug aus hochwertigem Kakao',
    image: '/images/choc-ing.avif',
    floatDistance: '-8px',
    floatSpeed: '4s',
  },
  {
    name: 'Crispy Balls',
    description: 'Knuspriger Kern für den Crunch-Faktor',
    image: '/images/balls-ing.avif',
    floatDistance: '-6px',
    floatSpeed: '3.5s',
  },
  {
    name: 'Soft Protein Kern',
    description: 'Weicher Proteinanteil mit echten Bananenchips',
    image: '/images/banana-ing.avif',
    floatDistance: '-10px',
    floatSpeed: '4.5s',
  },
]

const counters = [
  { value: product.nutrition.protein.value, suffix: '%', label: product.nutrition.protein.label },
  { value: product.nutrition.calories.value, suffix: '', label: product.nutrition.calories.label },
  { value: product.nutrition.sugar.value, suffix: 'g', label: product.nutrition.sugar.label },
]
---

<section id="home-details" class="py-20 lg:py-32 px-4">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 mb-16 lg:mb-24">
      <h2 class="text-3xl lg:text-5xl font-bold leading-tight">
        Originale Zutaten.<br />Einfach handgemacht.
      </h2>
      <p class="text-white/60 text-lg lg:text-xl leading-relaxed self-end">
        Ein Riegel, der nicht nur auf dem Papier überzeugt. Jede Zutat ist bewusst gewählt —
        für maximalen Geschmack bei minimalem Zucker. Handgemacht in Österreich.
      </p>
    </div>

    <!-- Nutrition Counters -->
    <div class="flex flex-wrap justify-center gap-8 lg:gap-16 mb-16 lg:mb-24">
      {counters.map((counter) => (
        <div class="text-center">
          <div class="text-4xl lg:text-6xl font-bold text-brand-500 mb-2">
            <span data-count={counter.value}>0</span>{counter.suffix}
          </div>
          <div class="text-sm text-white/50 uppercase tracking-widest">{counter.label}</div>
        </div>
      ))}
    </div>

    <!-- Ingredients Grid -->
    <div class="grid md:grid-cols-3 gap-8 lg:gap-12 mb-16 lg:mb-24">
      {ingredients.map((item) => (
        <div class="text-center">
          <div
            class="w-32 h-32 lg:w-40 lg:h-40 mx-auto mb-6 animate-float"
            style={`--float-distance: ${item.floatDistance}; --float-speed: ${item.floatSpeed}`}
          >
            <img
              src={item.image}
              alt={item.name}
              width="160"
              height="160"
              loading="lazy"
              class="w-full h-full object-contain"
            />
          </div>
          <h3 class="text-xl font-bold mb-2">{item.name}</h3>
          <p class="text-white/50 text-sm">{item.description}</p>
        </div>
      ))}
    </div>

    <!-- Cross-section Image -->
    <div class="relative flex justify-center">
      <img
        src="/images/RiegelQuerschnitt_detail.avif"
        alt="Gold Digger Riegel Querschnitt"
        width="800"
        height="400"
        loading="lazy"
        class="w-full max-w-2xl h-auto"
      />
      <span class="absolute bottom-4 right-4 lg:bottom-8 lg:right-8 inline-flex items-center px-4 py-2 bg-surface-800/80 backdrop-blur-sm rounded-full text-sm text-brand-500 border border-brand-500/20">
        {product.weight} pro Portion
      </span>
    </div>
  </div>
</section>

<script>
  function initCounters() {
    const counters = document.querySelectorAll<HTMLElement>('[data-count]')

    const startCount = (el: HTMLElement) => {
      const target = parseFloat(el.dataset.count || '0')
      let current = 0
      const duration = 3000
      const steps = 60
      const increment = target / steps

      const timer = setInterval(() => {
        current += increment
        if (current >= target) {
          current = target
          clearInterval(timer)
        }
        el.textContent =
          target % 1 === 0 ? String(Math.floor(current)) : current.toFixed(1)
      }, duration / steps)
    }

    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            startCount(entry.target as HTMLElement)
            obs.unobserve(entry.target)
          }
        })
      },
      { threshold: 0.4 }
    )

    counters.forEach((counter) => observer.observe(counter))
  }

  document.addEventListener('DOMContentLoaded', initCounters)
</script>
