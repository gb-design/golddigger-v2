---

---

<section class="py-20 lg:py-32 px-4 bg-surface-800">
  <div class="max-w-xl mx-auto text-center">
    <h2 class="text-3xl lg:text-4xl font-bold mb-4">
      Bleib am Goldkurs
    </h2>
    <p class="text-white/60 text-lg mb-10">
      News, Drops & exklusive Aktionen direkt in dein Postfach.
    </p>

    <form id="newsletter-form" class="space-y-4">
      <!-- Honeypot -->
      <div class="absolute -left-[9999px]" aria-hidden="true">
        <input type="text" name="honeypot" tabindex="-1" autocomplete="off" />
      </div>

      <div class="flex flex-col sm:flex-row gap-3">
        <input
          type="email"
          name="email"
          required
          placeholder="deine@email.at"
          class="flex-1 px-5 py-3.5 bg-surface-700 border border-brand-500/20 rounded-full text-white placeholder:text-white/30 focus:border-brand-500/50 focus:outline-none transition-colors"
        />
        <button
          type="submit"
          class="px-6 py-3.5 bg-brand-500 text-surface-900 font-bold rounded-full hover:bg-brand-400 transition-colors whitespace-nowrap"
        >
          Jetzt Gold sichern
        </button>
      </div>

      <!-- DSGVO Checkbox -->
      <label class="flex items-start gap-3 text-left cursor-pointer">
        <input
          type="checkbox"
          name="dsgvo"
          required
          class="mt-1 w-4 h-4 rounded border-brand-500/30 bg-surface-700 text-brand-500 focus:ring-brand-500 flex-shrink-0"
        />
        <span class="text-xs text-white/40 leading-relaxed">
          Ich stimme der Verarbeitung meiner Daten gemäß der
          <a href="/datenschutz" class="text-brand-500 underline underline-offset-2 hover:text-brand-400">Datenschutzerklärung</a>
          zu. Abmeldung jederzeit möglich.
        </span>
      </label>

      <!-- Response Message -->
      <div id="newsletter-message" class="hidden text-sm py-2 rounded-lg"></div>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement | null
  const messageEl = document.getElementById('newsletter-message')

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    if (!messageEl) return

    const formData = new FormData(form)
    const email = formData.get('email') as string
    const honeypot = formData.get('honeypot') as string

    try {
      const res = await fetch('/api/newsletter', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, honeypot }),
      })
      const data = await res.json()

      messageEl.classList.remove('hidden', 'text-red-400', 'text-green-400')
      messageEl.classList.add(data.success ? 'text-green-400' : 'text-red-400')
      messageEl.textContent = data.message
    } catch {
      messageEl.classList.remove('hidden', 'text-green-400')
      messageEl.classList.add('text-red-400')
      messageEl.textContent = 'Etwas ist schiefgelaufen. Versuch es später nochmal.'
    }
  })
</script>
