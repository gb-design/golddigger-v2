---
const steps = [
  { number: '01', title: 'Kaufen', description: 'Schnapp dir einen Gold Digger im Handel oder online.' },
  { number: '02', title: 'Code finden', description: 'Auf der Innenseite der Verpackung findest du deinen Code.' },
  { number: '03', title: 'Eingeben', description: 'Gib den Code auf unserer Website ein.' },
  { number: '04', title: 'Gewinnen', description: 'Mit etwas Glück gewinnst du einen von vielen Preisen!' },
]
---

<section id="home-win" class="py-20 lg:py-32 px-4">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16">
      <h3 class="text-3xl lg:text-4xl font-bold mb-6 max-w-2xl mx-auto">
        Du liebst Motivation, guten Geschmack und ein bisschen Glanz im Alltag?
      </h3>
      <p class="text-white/60 text-lg max-w-xl mx-auto">
        Dann mach mit bei unserem Gewinnspiel und sichere dir die Chance auf tolle Preise.
      </p>
    </div>

    <!-- Prize -->
    <div class="flex flex-col items-center mb-16">
      <!-- EUR 100 Badge -->
      <div class="relative mb-8">
        <svg width="160" height="160" viewBox="0 0 160 160" fill="none" xmlns="http://www.w3.org/2000/svg" class="drop-shadow-[0_0_30px_rgba(205,175,57,0.3)]">
          <circle cx="80" cy="80" r="78" stroke="#CDAF39" stroke-width="2" stroke-dasharray="6 4" />
          <circle cx="80" cy="80" r="65" fill="#CDAF39" fill-opacity="0.1" />
          <text x="80" y="65" text-anchor="middle" fill="#CDAF39" font-size="14" font-weight="bold" letter-spacing="3">GEWINNE</text>
          <text x="80" y="95" text-anchor="middle" fill="#CDAF39" font-size="32" font-weight="bold">€ 100</text>
          <text x="80" y="115" text-anchor="middle" fill="#CDAF39" font-size="12" letter-spacing="2">GUTSCHEIN</text>
        </svg>
      </div>

      <!-- Lottie -->
      <div class="win-lottie w-full max-w-xs h-20">
        <lottie-player
          src="/documents/lottieflow-cta-03-cdaf39-easey.json"
          background="transparent"
          speed="1.25"
          loop
          autoplay
          style="width: 100%; height: 100%"
        ></lottie-player>
      </div>
    </div>

    <!-- Steps -->
    <div class="mb-16">
      <h4 class="text-center text-xl font-bold mb-10">
        So bi<span class="text-brand-500">ss</span>t du dabei:
      </h4>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {steps.map((step) => (
          <div class="relative p-6 rounded-2xl border border-brand-500/10 bg-surface-800/50">
            <span class="text-4xl font-bold text-brand-500/20 mb-4 block">{step.number}</span>
            <h5 class="text-lg font-bold mb-2">{step.title}</h5>
            <p class="text-sm text-white/50">{step.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Partner -->
    <div class="text-center">
      <p class="text-xs uppercase tracking-widest text-white/30 mb-4">In Kooperation mit</p>
      <a href="https://www.fahrschule-schweden.at/" target="_blank" rel="noopener" class="inline-block opacity-60 hover:opacity-100 transition-opacity">
        <img
          src="/images/fahrschule_schweden.avif"
          alt="Fahrschule Schweden"
          width="180"
          height="60"
          loading="lazy"
          class="h-10 w-auto"
        />
      </a>
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        import('@lottiefiles/lottie-player')
        observer.disconnect()
      }
    })
  }, { rootMargin: '200px' })
  const el = document.querySelector('.win-lottie')
  if (el) observer.observe(el)
</script>
