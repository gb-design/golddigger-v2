---
import Marquee from './Marquee.astro'
import PriceTag from './PriceTag.astro'
import { product } from '../data/product'

const tickerItems = Array(6).fill('NEU im Handel')

const features = [
  { value: `${product.nutrition.protein.value}${product.nutrition.protein.unit}`, label: product.nutrition.protein.label },
  { value: `${product.nutrition.calories.value}`, label: product.nutrition.calories.label },
  { value: `${product.nutrition.sugar.value}${product.nutrition.sugar.unit}`, label: product.nutrition.sugar.label },
]

const floatingElements = [
  { src: '/images/choc-hero.avif', alt: '', class: 'top-[15%] left-[2%] lg:left-[5%] w-16 lg:w-24', floatDistance: '-8px', floatSpeed: '3.8s' },
  { src: '/images/nugget-hero.avif', alt: '', class: 'top-[30%] right-[3%] lg:right-[8%] w-12 lg:w-20 rotate-3', floatDistance: '-12px', floatSpeed: '4.6s' },
  { src: '/images/bananaChips-hero.avif', alt: '', class: 'bottom-[25%] left-[5%] lg:left-[10%] w-14 lg:w-20', floatDistance: '-6px', floatSpeed: '3.2s' },
  { src: '/images/nugget-hero-2.avif', alt: '', class: 'bottom-[15%] right-[5%] lg:right-[12%] w-10 lg:w-16 rotate-[2.5deg]', floatDistance: '-10px', floatSpeed: '5.1s' },
]

const diamondSvg = `<svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6 0L12 6L6 12L0 6L6 0Z" fill="#CDAF39"/></svg>`
---

<section class="relative overflow-hidden pt-20">
  <!-- Ticker -->
  <div class="border-y border-brand-500/20 py-3">
    <Marquee duration="25s">
      <div class="flex items-center gap-6 px-3">
        {tickerItems.map(() => (
          <span class="flex items-center gap-6">
            <span class="text-xs uppercase tracking-[0.2em] font-bold text-brand-500">NEU im Handel</span>
            <Fragment set:html={diamondSvg} />
          </span>
        ))}
      </div>
    </Marquee>
  </div>

  <!-- Hero Content -->
  <div class="relative max-w-7xl mx-auto px-4 lg:px-8 pt-12 lg:pt-20 pb-16 lg:pb-24">
    <!-- Floating deco elements -->
    {floatingElements.map((el) => (
      <div
        class:list={['absolute hidden lg:block animate-float pointer-events-none', el.class]}
        style={`--float-distance: ${el.floatDistance}; --float-speed: ${el.floatSpeed}`}
      >
        <img src={el.src} alt={el.alt} loading="lazy" class="w-full h-auto" />
      </div>
    ))}

    <!-- Product Photo -->
    <div class="flex justify-center mb-10 lg:mb-14" data-hero-anim="photo">
      <img
        src="/images/gd_riegelFoil.avif"
        srcset="/images/gd_riegelFoil-p-500.avif 500w, /images/gd_riegelFoil-p-800.avif 800w, /images/gd_riegelFoil-p-1080.avif 1080w, /images/gd_riegelFoil.avif 2700w"
        sizes="(max-width: 1040px) 100vw, 80vw"
        alt="Gold Digger Proteinriegel"
        width="2700"
        height="1200"
        loading="eager"
        fetchpriority="high"
        class="w-full max-w-3xl h-auto"
      />
    </div>

    <!-- Headline Block -->
    <div class="text-center max-w-3xl mx-auto" data-hero-anim>
      <h1 class="text-4xl lg:text-6xl xl:text-7xl font-bold uppercase leading-tight mb-4">
        Der Proteinriegel, der motiviert
      </h1>
      <p class="text-lg lg:text-xl text-white/60 mb-6">
        Wer das Gold hat, macht die Regeln.
      </p>
      <div class="flex justify-center mb-8">
        <PriceTag />
      </div>
    </div>

    <!-- Feature Badges -->
    <div class="flex flex-wrap justify-center gap-6 lg:gap-10 mb-10" data-hero-anim>
      {features.map((feature) => (
        <div class="flex items-center gap-3">
          <Fragment set:html={diamondSvg} />
          <div>
            <span class="text-xl lg:text-2xl font-bold text-brand-500">{feature.value}</span>
            <span class="ml-2 text-sm text-white/50">{feature.label}</span>
          </div>
        </div>
      ))}
    </div>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4" data-hero-anim>
      <a
        href={product.shopUrl}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-8 py-4 bg-brand-500 text-surface-900 font-bold text-lg rounded-full hover:bg-brand-400 transition-colors"
      >
        Jetzt bestellen — EUR 2,99
      </a>
      <a
        href="#home-win"
        class="inline-flex items-center gap-2 px-8 py-4 border border-brand-500/40 text-brand-500 font-bold rounded-full hover:bg-brand-500/10 transition-colors"
      >
        Zum Gewinnspiel
      </a>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap'

  function initHeroAnimation() {
    const elements = document.querySelectorAll('[data-hero-anim]')
    if (!elements.length) return

    gsap.set(elements, { opacity: 0, y: 30 })
    gsap.to(elements, {
      opacity: 1,
      y: 0,
      duration: 0.8,
      stagger: 0.15,
      ease: 'power2.out',
      delay: 0.3,
    })
  }

  document.addEventListener('DOMContentLoaded', initHeroAnimation)
</script>
